# Helius — the entire ingestion path runs on Helius (RPC + webhooks/Laserstream)
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET_MAINNET=
HELIUS_WEBHOOK_SECRET_DEVNET=

# Infra
DATABASE_URL=postgres://onrecord:onrecord@localhost:5432/onrecord
# Redis is only used by the queued worker path (dev:worker). The single-process
# live deployment (start:live) runs the pipeline inline and ignores this.
REDIS_URL=redis://localhost:6379

# Ops
ADMIN_PASSWORD=change-me
PORT=3001
PUBLIC_API_URL=http://localhost:3001

# Live poller (start:live / dev:live) — near-real-time loader ingestion.
# Each tick spends 2× getProgramAccounts (10 credits each) + 1× getSlot on Helius.
# 5 min ≈ 180k credits/mo (~18% of the free plan's 1M); 2 min ≈ 45%. Lower the
# interval only on a paid plan or after switching enumeration to getProgramAccountsV2.
LIVE_POLL_ENABLED=1
LIVE_POLL_INTERVAL_MS=300000
LIVE_POLL_BOOTSTRAP_HOURS=1
LIVE_POLL_MAX=200

# Web (apps/web)
API_URL=http://localhost:3001
